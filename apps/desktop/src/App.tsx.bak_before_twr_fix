    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();

  const aliases: Record<string, string> = {
    date: "date",
    "date operation": "date",
    "date d operation": "date",
    "date ordre": "date",
    type: "type",
    "type operation": "type",
